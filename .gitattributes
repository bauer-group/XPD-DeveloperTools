# Set default behavior to automatically normalize line endings
* text=auto

# Shell scripts: LF line endings
# Note: File permissions (chmod +x) are tracked by Git's index, not gitattributes.
# To avoid permission conflicts on clones, run: git config core.fileMode false
# This is handled automatically by install.sh and update.sh
*.sh text eol=lf

# Python scripts: LF line endings
# These run inside the Linux devtools container via their shebang. With CRLF
# the kernel reads the interpreter as "python3\r", which fails with
# "env: 'python3\r': No such file or directory" on Windows checkouts.
*.py text eol=lf

# YAML files should use LF
*.yml text eol=lf
*.yaml text eol=lf

# Markdown can use any line ending
*.md text

# Environment files (if tracked)
.env* text eol=lf

# Keep binary files as-is
*.png binary
*.jpg binary
